# Supabase（在 https://supabase.com 创建免费项目后获取）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# Auth 访问门禁（自定义你的用户名密码）
AUTH_USERNAME=your_username
AUTH_PASSWORD=your_strong_password
# 用于 cookie 签名，建议 32 字节随机串：openssl rand -hex 32
AUTH_SECRET=replace_with_random_hex_string
