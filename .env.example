# Supabase（在 https://supabase.com 创建免费项目后获取）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# Cookie 签名密钥（32 字节随机串：openssl rand -hex 32）
# 账号本身存在 Supabase 的 app_users 表里，见 supabase/migration-003-multi-user.sql
AUTH_SECRET=replace_with_random_hex_string
